# Core
DATABASE_URL=postgresql+psycopg://signal:signal@localhost:5432/signal_agent
LOG_LEVEL=INFO
ENV=dev

# Anthropic (LLM validation + scoring summaries)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# HubSpot — private app token with scopes:
#   crm.objects.companies.read, crm.objects.companies.write
#   crm.schemas.companies.read, crm.schemas.companies.write
#   timeline (for custom timeline events)
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_TIMELINE_APP_ID=
HUBSPOT_TIMELINE_EVENT_TEMPLATE_ID=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ALERT_CHANNEL=#gtm-signals-test
SLACK_OWNER_USER_ID=          # who gets pinged when circuit breaker trips

# Inngest — leave event/signing keys blank for local dev (use `inngest-cli dev`)
INNGEST_APP_ID=signal-agent
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1

# Scoring tuning
ALERT_SCORE_THRESHOLD=8
ALERT_CUMULATIVE_THRESHOLD=12
ALERT_CUMULATIVE_WINDOW_DAYS=60
LLM_CONFIDENCE_FLOOR=0.7
CIRCUIT_BREAKER_ALERTS_PER_HOUR=20
DIGEST_RATE_THRESHOLD=5
DIGEST_FLUSH_INTERVAL_MINUTES=15
# Same-signal-type rolling cooldown (days): a company can't re-alert on
# the same signal_type for this many days after the prior post. Orthogonal
# to the 24h general cooldown.
ALERT_SAME_TYPE_COOLDOWN_DAYS=7
# LLM cache TTL (days). Must be >= ALERT_CUMULATIVE_WINDOW_DAYS so signals
# inside the scoring window never miss cache. Default = 60 + 7 headroom.
LLM_CACHE_TTL_DAYS=67

# Arthur tracing — export LLM calls + pipeline spans to your Arthur Engine.
# ARTHUR_TASK_ID is shown in the Arthur UI at Model Management → API Key after
# you create an Agentic Model.
ARTHUR_TRACING_ENABLED=1
ARTHUR_ENGINE_BASE_URL=http://localhost:3030
ARTHUR_ENGINE_API_KEY=
ARTHUR_TASK_ID=
ARTHUR_SERVICE_NAME=signal-agent
